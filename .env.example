# Auto-Vote-Rating Environment Configuration
# Copy this file to .env and adjust the values for your environment

# =============================================================================
# CDP (Chrome DevTools Protocol) Configuration
# =============================================================================
# This is the address users will use to access the manual captcha browser
#
# FOR LOCAL DEVELOPMENT (Mac/Windows/Linux):
# Use 'localhost' or '127.0.0.1'
CDP_PUBLIC_HOST=localhost

# FOR PRODUCTION DEPLOYMENT (Server):
# Use your server's public IP address or domain
# Examples:
#   CDP_PUBLIC_HOST=192.168.1.100
#   CDP_PUBLIC_HOST=10.0.0.5
#   CDP_PUBLIC_HOST=your-server.com

# =============================================================================
# Optional: CDP Authentication Token
# =============================================================================
# Leave empty to auto-generate a random token on startup
# Or set a custom token for persistent access
# CDP_AUTH_TOKEN=your-custom-token-here

# =============================================================================
# Timezone Configuration
# =============================================================================
# Set your timezone for scheduling votes
# TZ=America/New_York
# TZ=Europe/London
# TZ=Asia/Tokyo
